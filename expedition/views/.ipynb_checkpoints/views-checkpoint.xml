<odoo>
  <data>

    <record id="view_expedition_BP" model="ir.ui.view">
        <field name="name">stock.view.form.BP</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='origin']" position="after">
                    <field name="ip" invisible="1"/>
                    <field name="identifier" invisible="1"/>
                    <field name="device_id" required="1" string="Matériel"/>
<!--                     <group name="groupValeur">
                        <div> -->
<!--                     <label for="valeur" style="font-weight: bold;"/> -->
                    <field name="valeur" widget="iot_realtime_value" options="{'ip_field': 'ip', 'identifier': 'identifier'}"/>
                    <button name="valueTo" class="btn-primary" id="button_id" type="object" string="Python call" />
<!--                         </div>
                    </group> -->
<!--                     <field name="leContext"/> -->
<!--                     <field name="lesInfos"/> -->
                </xpath>
                <xpath expr="//group" position="after">
                    <group>
                        <group name="group_balance" string="Balance">
                            <div class="o_row">
                                <label for="valeur" style="font-weight:bold; font-size: 16px;"/>
                                <field name="valeur" widget="iot_realtime_value" style="font-size: 16px" options="{'ip_field': 'ip', 'identifier': 'identifier'}"/>
                            </div>
                        </group>
                    </group>
                </xpath>
            </data>
        </field>
    </record>
    
    <record id="view_expedition_button_BP" model="ir.ui.view">
        <field name="name">stock.view.button.BP</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//field[@name='quantity_done']" position="after">
                    <button name="getPoids" class="btn-primary fa fa-balance-scale oe_edit_only" id="button_id" type="object" string=" Peser"/>
                </xpath>
            </data>
        </field>
    </record>

  </data>
</odoo>